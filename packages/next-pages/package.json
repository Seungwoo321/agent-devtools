{
  "name": "@agent-devtools/next-pages",
  "version": "0.7.0-beta.0",
  "description": "Next.js Pages Router adapter for agent-devtools — wraps the React widget for legacy pages/_app.tsx hosts",
  "keywords": [
    "agent-devtools",
    "devtools",
    "next",
    "nextjs",
    "pages-router",
    "claude",
    "llm",
    "dev-only"
  ],
  "license": "MIT",
  "author": "Seungwoo Lee <seungwoo321@gmail.com>",
  "homepage": "https://github.com/Seungwoo321/agent-devtools/tree/main/packages/next-pages#readme",
  "bugs": {
    "url": "https://github.com/Seungwoo321/agent-devtools/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "import": "./dist/bootstrap.js",
      "default": "./dist/bootstrap.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@agent-devtools/core": "workspace:*",
    "@agent-devtools/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Seungwoo321/agent-devtools.git",
    "directory": "packages/next-pages"
  }
}
