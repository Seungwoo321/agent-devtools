{
  "name": "@agent-devtools/example-nuxt",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --port 3300",
    "build": "nuxt build",
    "build:check": "nuxt build && node scripts/check-no-leak.mjs",
    "smoke:no-leak": "node scripts/check-no-leak.mjs",
    "preview": "nuxt preview --port 3300",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "postinstall": "nuxt prepare"
  },
  "devDependencies": {
    "@agent-devtools/nuxt": "workspace:*",
    "@agent-devtools/vue": "workspace:*",
    "nuxt": "^3.13.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
