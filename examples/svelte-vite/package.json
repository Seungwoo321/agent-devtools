{
  "name": "@agent-devtools/example-svelte-vite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3203",
    "build": "vite build",
    "build:check": "vite build && node scripts/check-no-leak.mjs",
    "smoke:no-leak": "node scripts/check-no-leak.mjs",
    "preview": "vite preview --port 4203",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@agent-devtools/svelte": "workspace:*",
    "@agent-devtools/vite": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.12"
  }
}
