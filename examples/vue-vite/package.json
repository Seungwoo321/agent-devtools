{
  "name": "@agent-devtools/example-vue-vite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3200",
    "build": "vue-tsc --noEmit && vite build",
    "build:check": "vue-tsc --noEmit && vite build && node scripts/check-no-leak.mjs",
    "smoke:no-leak": "node scripts/check-no-leak.mjs",
    "preview": "vite preview --port 3200",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@agent-devtools/core": "workspace:*",
    "@agent-devtools/vite": "workspace:*",
    "@agent-devtools/vue": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vue-tsc": "^2.2.0"
  }
}
